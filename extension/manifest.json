{
  "manifest_version": 3,
  "key": "",
  "name": "한국어 맞춤법 검사기 (로컬 Claude)",
  "version": "0.1.1",
  "description": "로컬 Claude Code CLI로 웹 입력창의 한국어 맞춤법을 교정합니다. API 과금 없음.",
  "permissions": ["storage", "activeTab", "scripting", "nativeMessaging"],
  "background": { "service_worker": "background.js" },
  "content_scripts": [
    { "matches": ["<all_urls>"], "js": ["content.js"], "css": ["content.css"], "run_at": "document_idle" }
  ],
  "options_page": "options.html",
  "action": { "default_popup": "popup.html", "default_title": "한국어 맞춤법 검사기" },
  "commands": {
    "check-spelling": {
      "suggested_key": { "default": "Ctrl+Shift+K" },
      "description": "선택한 텍스트 또는 현재 입력창 맞춤법 검사"
    }
  }
}
